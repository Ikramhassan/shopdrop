# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/shopdrop"

# Set to true if your PostgreSQL requires SSL (e.g. cloud DBs)
DATABASE_SSL=false

# Change this to a long random string in production!
JWT_SECRET="change-this-to-a-secure-random-string"

PORT=5000
NODE_ENV=production

# Origins allowed to call the API (comma-separated)
ALLOWED_ORIGINS="https://wow.idzlink.com"

# Next.js port (used by proxy)
NEXT_PORT=3000

# AliExpress Affiliate API (optional - can set via Admin UI)
ALIEXPRESS_APP_KEY=""
ALIEXPRESS_APP_SECRET=""
