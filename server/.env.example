# PostgreSQL — copy from wa-ai-replier but change DB name to shopdrop
DATABASE_URL="postgresql://pgadmin:YOUR_PASSWORD@pgadmin.idzlink.com:5432/shopdrop"
DATABASE_SSL=false

# Change this to a long random string in production!
JWT_SECRET="your-secret-here"

PORT=5000
NODE_ENV=production

# Comma-separated allowed origins
ALLOWED_ORIGINS="https://wow.idzlink.com"
NEXT_PORT=3000

# AliExpress Affiliate API (optional — can also set via Admin UI)
ALIEXPRESS_APP_KEY=""
ALIEXPRESS_APP_SECRET=""
